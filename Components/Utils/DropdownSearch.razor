@using Microsoft.JSInterop
@using PokeBreedr.Models
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="dropdown-search" @ref="DropdownRef">

    <input class="dropdown-input"
           type="text"
           placeholder="Search..."
           value="@SearchText"
           @oninput="OnInput"
           @onfocus="OpenDropdown" />

    @if (IsOpen)
    {
        <div class="dropdown-options">

            @if (FilteredOptions.Any())
            {
                @foreach (var option in FilteredOptions)
                {
                    <div class="dropdown-option"
                         @onclick="() => SelectOption(option)">

                        @option.Label

                    </div>
                }
            }
            else
            {
                <div class="dropdown-empty">
                    Sin resultados
                </div>
            }

        </div>
    }

</div>

@code {

    [Parameter]
    public List<DropdownOption> Options { get; set; } = new();

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    private bool IsOpen = false;

    private string SearchText = "";

    private ElementReference DropdownRef;

    private DotNetObjectReference<DropdownSearch>? ObjRef;

    private string ListenerId = Guid.NewGuid().ToString();

    protected override void OnParametersSet()
    {
        var selected = Options.FirstOrDefault(x => x.Value == Value);

        if (selected is not null)
        {
            SearchText = selected.Label;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ObjRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync(
                "dropdownInterop.registerOutsideClick",
                ListenerId,
                DropdownRef,
                ObjRef);
        }
    }

    private List<DropdownOption> FilteredOptions =>
        string.IsNullOrWhiteSpace(SearchText)
            ? Options
            : Options.Where(x =>
                    x.Label.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                    x.Value.Contains(SearchText, StringComparison.OrdinalIgnoreCase))
                .ToList();

    private void OpenDropdown()
    {
        IsOpen = true;
    }

    [JSInvokable]
    public void CloseDropdown()
    {
        IsOpen = false;

        StateHasChanged();
    }

    private async Task SelectOption(DropdownOption option)
    {
        SearchText = option.Label;

        IsOpen = false;

        Value = option.Value;

        await ValueChanged.InvokeAsync(option.Value);
    }

    private void OnInput(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString() ?? "";

        IsOpen = true;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "dropdownInterop.unregisterOutsideClick",
                ListenerId);
        }
        catch
        {
            // ignorar si el componente ya murió
        }

        ObjRef?.Dispose();
    }
}