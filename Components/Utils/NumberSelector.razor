<div class="number-selector">

    <button @onclick="SetMin">Min</button>

    <button @onclick="() => Change(-StepLarge)">-@StepLarge</button>
    <button @onclick="() => Change(-StepSmall)">-@StepSmall</button>

    <input type="number"
           value="@CurrentValue"
           min="@MinValue"
           max="@MaxValue"
           @oninput="OnInput"
           class="value-input" />

    <button @onclick="() => Change(StepSmall)">+@StepSmall</button>
    <button @onclick="() => Change(StepLarge)">+@StepLarge</button>

    <button @onclick="SetMax">Max</button>

</div>

@code {

    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }

    [Parameter] public int MinValue { get; set; } = 0;
    [Parameter] public int MaxValue { get; set; } = 100;

    [Parameter] public int StepSmall { get; set; } = 1;
    [Parameter] public int StepLarge { get; set; } = 10;

    private int CurrentValue
    {
        get
        {
            var clamped = Math.Clamp(Value, MinValue, MaxValue);
            return clamped;
        }
        set
        {
            var clamped = Math.Clamp(value, MinValue, MaxValue);
            if (Value != clamped)
            {
                Value = clamped;
                CurrentValue = clamped;
                ValueChanged.InvokeAsync(Value);
            }
        }
    }

    private void Change(int delta)
        => CurrentValue += delta;

    private void SetMin()
        => CurrentValue = MinValue;

    private void SetMax()
        => CurrentValue = MaxValue;

    private void OnInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            var clamped = Math.Clamp(v, MinValue, MaxValue);
            CurrentValue = clamped;
        }
    }
}