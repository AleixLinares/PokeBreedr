@using PokeBreedr.Components.Cards
@using PokeBreedr.Components.Utils
@using PokeBreedr.Interfaces
@using PokeBreedr.Models
@using PokeBreedr.Dto
@using PokeBreedr.Services


<div class="daycare-base">
        <div class="daycare-selector">
            <label>Select a Configuration</label>

        <DropdownSearch Options="ConfigurationNames"
                        Value="@SelectedValue"
                        ValueChanged="OnPokemonChanged"/>
        </div>

    @if (SelectedCard != null)
    {
        <ConfigCard @key="SelectedCard.Guid"
              Model="SelectedCard"       
              DisableAll="@true" />

        <button class="add-btn" @onclick="Combine">
            Combine all
        </button>

        @foreach (var item in CombinedPokemons)
        {
            <CombinationCard
                        Model="item"
                        OnSave="TransferPokemon" />
        }
    }

   
    
</div>


@code {
    private List<DropdownOption> ConfigurationNames = new();

    [Parameter]
    public string? SelectedValue { get; set; } = null;

    [Inject]
    private IBreedConfigPersistenceService BreedConfigPersistenceService { get; set; } = default!;

    [Inject]
    private IPokemonPersistenceService PokemonPersistanceService { get; set; } = default!;

    [Inject]
    private BreederService BreederService { get; set; } = default!;

    private ConfigCardInfo? SelectedCard { get; set; } = null;
    private List<CombinationInfo> CombinedPokemons = new List<CombinationInfo>();

    public bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        var configNames = await this.BreedConfigPersistenceService.GetAllConfigurationsName();

        foreach (string configName in configNames)
        {
            var dropdownOption = new DropdownOption();
            dropdownOption.Value = configName;
            dropdownOption.Label = configName;
            ConfigurationNames.Add(dropdownOption);
        }
    }

    private async Task OnPokemonChanged(string configurationName)
    {
        ConfigCardInfoDto? configCard = await this.BreedConfigPersistenceService.GetConfigurationByName(configurationName);

        if (configCard != null)
        {
            this.SelectedCard = new ConfigCardInfo(configCard);
            this.SelectedValue = configurationName;
            this.CombinedPokemons = new List<CombinationInfo>();
        }          
    }

    private async Task Combine()
    {
        List<PokemonInfoDto> dtoList = await PokemonPersistanceService.GetAll();
        if (SelectedCard != null)
        {
            ConfigCardInfoDto configDto = new ConfigCardInfoDto(SelectedCard);
            CombinedPokemons = this.BreederService.BreedPokemons(dtoList, configDto);            
        }
    }

    private async Task TransferPokemon(TransferPokemonDto model)
    {
        await PokemonPersistanceService.Save(model.Pokemon);
        await PokemonPersistanceService.Delete(model.Parent1);
        await PokemonPersistanceService.Delete(model.Parent2);
        CombinedPokemons = CombinedPokemons
            .Where(i => (i.Parent1 != model.Parent1 && i.Parent1 != model.Parent2) 
                    && (i.Parent2 != model.Parent1 && i.Parent2 != model.Parent2)).ToList();
    }
}