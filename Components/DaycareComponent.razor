@using PokeBreedr.Components.Cards
@using PokeBreedr.Components.Utils
@using PokeBreedr.Interfaces
@using PokeBreedr.Models
@using PokeBreedr.Dto
@using PokeBreedr.Services

@inject ToastService ToastService

<div class="daycare-base">
        <div class="daycare-selector">
            <label>Select a Configuration</label>

        <DropdownSearch Options="ConfigurationNames"
                        Value="@SelectedValue"
                        ValueChanged="OnConfigurationChanged"/>
        </div>

    @if (SelectedCard != null)
    {
        <ConfigCard @key="SelectedCard.Guid"
              Model="SelectedCard"       
              DisableAll="@true" />

        <button class="add-btn" @onclick="Combine">
            Combine all
        </button>

        if (showingCombinations)
        {
            <div class="dropdown-row">
                <DropdownSearch2 @ref="Parent1Dropdown" 
                    Options="Parents1"
                                ValueChanged="OnParent1Selected" />

                <DropdownSearch2 @ref="Parent2Dropdown"
                    Options="Parents2"
                                isDisabled="@(string.IsNullOrEmpty(SelectedParent1))"
                                ValueChanged="OnParent2Selected" />
            </div>
            @foreach (var item in CombinedPokemonsShow)
            {
                <CombinationCard @key="@($"{item.Parent1}-{item.Parent2}")"
                Model="item"
                OnSave="TransferPokemon" />
            }
        }
    }

   
    
</div>


@code {
    private List<DropdownOption> ConfigurationNames = new();

    [Parameter]
    public string? SelectedValue { get; set; } = null;

    [Inject]
    private IBreedConfigPersistenceService BreedConfigPersistenceService { get; set; } = default!;

    [Inject]
    private IPokemonPersistenceService PokemonPersistanceService { get; set; } = default!;

    [Inject]
    private BreederService BreederService { get; set; } = default!;

    private ConfigCardInfo? SelectedCard { get; set; } = null;
    private List<CombinationInfo> CombinedPokemonsBase = new List<CombinationInfo>();
    private List<CombinationInfo> CombinedPokemonsShow = new List<CombinationInfo>();
    private List<DropdownOption> Parents1 = new List<DropdownOption>();
    private List<DropdownOption> Parents2 = new List<DropdownOption>();

    public bool isLoading = false;
    private bool showingCombinations = false;

    public string? SelectedParent1 { get; set; } = null;
    public string? SelectedParent2 { get; set; } = null;
    private DropdownSearch2? Parent1Dropdown;
    private DropdownSearch2? Parent2Dropdown;

    protected override async Task OnInitializedAsync()
    {
        var configNames = await this.BreedConfigPersistenceService.GetAllConfigurationsName();

        foreach (string configName in configNames)
        {
            var dropdownOption = new DropdownOption();
            dropdownOption.Value = configName;
            dropdownOption.Label = configName;
            ConfigurationNames.Add(dropdownOption);
        }
    }

    private async Task OnConfigurationChanged(string configurationName)
    {
        showingCombinations = false;
        Parent2Dropdown?.EmptySearchSyting();
        Parent1Dropdown?.EmptySearchSyting();
        ConfigCardInfoDto? configCard = await this.BreedConfigPersistenceService.GetConfigurationByName(configurationName);

        if (configCard != null)
        {
            this.SelectedCard = new ConfigCardInfo(configCard);
            this.SelectedValue = configurationName;
            this.CombinedPokemonsBase = new List<CombinationInfo>();
            this.CombinedPokemonsShow = new List<CombinationInfo>();
        }          
    }

    private async Task Combine()
    {
        showingCombinations = false;

        Parent2Dropdown?.EmptySearchSyting();
        Parent1Dropdown?.EmptySearchSyting();
        try
        {
            if (SelectedCard == null)
            {
                await ToastService.Info("Please select a configuration card first.");
                return;
            }

            List<PokemonInfoDto> dtoList = await PokemonPersistanceService.GetAll();

            ConfigCardInfoDto configDto = new ConfigCardInfoDto(SelectedCard);
            CombinedPokemonsBase = this.BreederService.BreedPokemons(dtoList, configDto);
            await ToastService.Info($"Found {CombinedPokemonsBase.Count} matching combinations.");

            Parents1.Clear();

            foreach (var combination in CombinedPokemonsBase)
            {
                var parent1Task = PokemonPersistanceService.Obtain(combination.Parent1);
                var parent2Task = PokemonPersistanceService.Obtain(combination.Parent2);

                await Task.WhenAll(parent1Task, parent2Task);

                AddParentOption(parent1Task.Result);
                AddParentOption(parent2Task.Result);
            }

            showingCombinations = true;
            this.CombinedPokemonsShow = CombinedPokemonsBase.ToList();
        }
        catch
        {
            await ToastService.Error("Failed to generate Pokémon combinations. Please try again.");
        }
    }

    private void AddParentOption(PokemonInfoDto? parent, bool parent1 = true)
    {
        if (parent == null)
            return;

        var option = new DropdownOption
        {
            Value = parent.Guid.ToString(),
            Label = BuildPokemonLabel(parent)
        };

        if (parent1)
        {
            if (!Parents1.Any(x => x.Value == option.Value))
            {
                Parents1.Add(option);
            }
        }
        else
        {
            if (!Parents2.Any(x => x.Value == option.Value))
            {
                Parents2.Add(option);
            }
        }

    }

    private static string BuildPokemonLabel(PokemonInfoDto pokemon)
    {
        var nickname = string.IsNullOrWhiteSpace(pokemon.Name)
            ? "No nickname"
            : pokemon.Name;

        return $"{pokemon.Pokemon} ({nickname}) " +
               $"{pokemon.HpIv}-{pokemon.AttackIv}-{pokemon.DefenseIv}-" +
               $"{pokemon.SpAttackIv}-{pokemon.SpDefenseIv}-{pokemon.SpeedIv}";
    }

    private async Task TransferPokemon(TransferPokemonDto model)
    {
        try
        {
            await PokemonPersistanceService.Save(model.Pokemon);
            await PokemonPersistanceService.Delete(model.Parent1);
            await PokemonPersistanceService.Delete(model.Parent2);

            CombinedPokemonsBase = CombinedPokemonsBase
                .Where(i =>
                    (i.Parent1 != model.Parent1 && i.Parent1 != model.Parent2) &&
                    (i.Parent2 != model.Parent1 && i.Parent2 != model.Parent2))
                .ToList();

            this.CombinedPokemonsShow = CombinedPokemonsBase.ToList();

            await ToastService.Success("Pokémon transferred successfully.");
        }
        catch (Exception)
        {
            await ToastService.Error("Failed to transfer Pokémon. Please try again.");
        }
    }

    private async Task OnParent1Selected(string? selectedGuid)
    {        
        SelectedParent1 = selectedGuid;
        Parent2Dropdown?.EmptySearchSyting();
        Parents2.Clear();
        SelectedParent2 = null;
        var hasParent = Guid.TryParse(SelectedParent1, out var parent);
        if (hasParent)
        {
            var otherParentGuids = CombinedPokemonsBase
                .Where(i => i.Parent1 == parent || i.Parent2 == parent)
                .Select(i => i.Parent1 == parent ? i.Parent2 : i.Parent1)
                .Distinct()
                .ToList();
            Console.WriteLine("otherParentGuids" + otherParentGuids.Count.ToString());
            foreach (var otherGuid in otherParentGuids)
            {
                var other = await this.PokemonPersistanceService.Obtain(otherGuid);
                AddParentOption(other, false);
            }
            Console.WriteLine("parents2" + Parents2.Count.ToString());
        }

        ApplyFilters();
    }

    private void OnParent2Selected(string? selectedGuid)
    {
        SelectedParent2 = selectedGuid;

        Console.WriteLine("Aplicando filtros 2");
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var query = CombinedPokemonsBase.AsEnumerable();

        var hasParent1 = Guid.TryParse(SelectedParent1, out var parent1);
        var hasParent2 = Guid.TryParse(SelectedParent2, out var parent2);
        Console.WriteLine("hasParent1" + hasParent1.ToString());
        Console.WriteLine("hasParent2" + hasParent2.ToString());

        if (hasParent1 && hasParent2)
        {
            query = query.Where(i =>
                (i.Parent1 == parent1 && i.Parent2 == parent2) ||
                (i.Parent1 == parent2 && i.Parent2 == parent1));
        }
        else if (hasParent1)
        {
            query = query.Where(i =>
                i.Parent1 == parent1 ||
                i.Parent2 == parent1);
        }
        else if (hasParent2)
        {
            query = query.Where(i =>
                i.Parent1 == parent2 ||
                i.Parent2 == parent2);
        }

        CombinedPokemonsShow = query.ToList();

        StateHasChanged();
    }
}