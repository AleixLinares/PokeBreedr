@using PokeBreedr.Components.Utils
@using PokeBreedr.Enums
@using PokeBreedr.Models
@using PokeBreedr.Dto

<div class="config-card-container">

    <!-- HEADER -->
    <div class="config-card-header">

        <div>
            <label>Configuration Name</label>

            <input class="config-text-input"
                   maxlength="200"
                   @bind="Model.ConfigName"
                   placeholder="Write configuration name..." />
        </div>

    </div>

    <!-- BODY -->
    <div class="config-card-body">

        <div class="config-main-grid">

            <!-- LEFT -->
            <div class="config-left">

                <div class="config-section">
                    <div class="section-title">Filters</div>

                    <div class="field">
                        <label class="checkbox-label">
                            <span>Only Alfa:</span>
                            <input type="checkbox"
                                   class="card-checkbox"
                                   @bind="Model.OnlyAlfa" />
                        </label>
                    </div>

                    <div class="field">
                        <label>Egg Group 1</label>
                        <Dropdown TValue="string"
                                  Options="EggGroupOptions"
                                  @bind-Value="Model.OnlyEggGroup1" />
                    </div>

                    <div class="field">
                        <label>Egg Group 2</label>
                        <Dropdown TValue="string"
                                  Options="EggGroupOptions"
                                  @bind-Value="Model.OnlyEggGroup2" />
                    </div>

                    <div class="field">
                        <label>Natures</label>

                        <DropdownMultiple TValue="string"
                                          Options="NatureOptions"
                                          Values="Model.SelectedNatures"
                                          ValuesChanged="OnNaturesChanged" />
                    </div>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="config-right">

                <div class="config-section">
                    <div class="section-title">IV Filters</div>

                    <div class="iv-stack">

                        <div class="iv-row">
                            <span>HP</span>
                            <input type="number" class="iv-input" @bind="Model.MinHpIv" />
                            <span>→</span>
                            <input type="number" class="iv-input" @bind="Model.MaxHpIv" />
                        </div>

                        <div class="iv-row">
                            <span>Attack</span>
                            <input type="number" class="iv-input" @bind="Model.MinAttackIv" />
                            <span>→</span>
                            <input type="number" class="iv-input" @bind="Model.MaxAttackIv" />
                        </div>

                        <div class="iv-row">
                            <span>Defense</span>
                            <input type="number" class="iv-input" @bind="Model.MinDefenseIv" />
                            <span>→</span>
                            <input type="number" class="iv-input" @bind="Model.MaxDefenseIv" />
                        </div>

                        <div class="iv-row">
                            <span>SpA</span>
                            <input type="number" class="iv-input" @bind="Model.MinSpAttackIv" />
                            <span>→</span>
                            <input type="number" class="iv-input" @bind="Model.MaxSpAttackIv" />
                        </div>

                        <div class="iv-row">
                            <span>SpD</span>
                            <input type="number" class="iv-input" @bind="Model.MinSpDefenseIv" />
                            <span>→</span>
                            <input type="number" class="iv-input" @bind="Model.MaxSpDefenseIv" />
                        </div>

                        <div class="iv-row">
                            <span>Speed</span>
                            <input type="number" class="iv-input" @bind="Model.MinSpeedIv" />
                            <span>→</span>
                            <input type="number" class="iv-input" @bind="Model.MaxSpeedIv" />
                        </div>

                    </div>
                </div>

            </div>

        </div>

    </div>

    <!-- ACTIONS -->
    <div>

        <button class="card-button" @onclick="Save">
            @(Model.IsSaved ? "Update" : "Save")
        </button>

        <button class="card-button" @onclick="Cancel">
            Cancel
        </button>

    </div>

</div>

@code {

    [Parameter]
    public ConfigCardInfo Model { get; set; } = default!;

    [Parameter]
    public EventCallback<ConfigCardInfo> OnSave { get; set; }

    [Parameter]
    public EventCallback<ConfigCardInfo> OnCancel { get; set; }

    [Parameter]
    public EventCallback<ConfigCardInfo> OnDelete { get; set; }

    private async Task Save()
    {
        await OnSave.InvokeAsync(Model);
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync(Model);
    }

    private async Task Delete()
    {
        await OnDelete.InvokeAsync(Model);
    }

    private async Task OnNaturesChanged(List<string?> values)
    {
        Model.SelectedNatures = values;

        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        NatureOptions = NatureOptions.OrderBy(i => i.Label).ToList();
    }

    private List<DropdownOption> EggGroupOptions = new()
    {
        new() { Value = "", Label = "Any" },
        new() { Value = "Monster", Label = "Monster" },
        new() { Value = "Dragon", Label = "Dragon" },
        new() { Value = "Water 1", Label = "Water 1" },
        new() { Value = "Water 2", Label = "Water 2" },
        new() { Value = "Water 3", Label = "Water 3" },
        new() { Value = "Bug", Label = "Bug" },
        new() { Value = "Flying", Label = "Flying" },
        new() { Value = "Field", Label = "Field" },
        new() { Value = "Fairy", Label = "Fairy" },
        new() { Value = "Grass", Label = "Grass" },
        new() { Value = "Human-Like", Label = "Human-Like" },
        new() { Value = "Mineral", Label = "Mineral" },
        new() { Value = "Amorphous", Label = "Amorphous" },
        new() { Value = "Ditto", Label = "Ditto" },
        new() { Value = "Genderless", Label = "Genderless" }
    };

    private List<DropdownOption> NatureOptions = new()
    {
        new() { Value = PokemonNatureEnum.Hardy.ToString(), Label = "Hardy" },
        new() { Value = PokemonNatureEnum.Lonely.ToString(), Label = "Lonely" },
        new() { Value = PokemonNatureEnum.Brave.ToString(), Label = "Brave" },
        new() { Value = PokemonNatureEnum.Adamant.ToString(), Label = "Adamant" },
        new() { Value = PokemonNatureEnum.Naughty.ToString(), Label = "Naughty" },

        new() { Value = PokemonNatureEnum.Bold.ToString(), Label = "Bold" },
        new() { Value = PokemonNatureEnum.Docile.ToString(), Label = "Docile" },
        new() { Value = PokemonNatureEnum.Relaxed.ToString(), Label = "Relaxed" },
        new() { Value = PokemonNatureEnum.Impish.ToString(), Label = "Impish" },
        new() { Value = PokemonNatureEnum.Lax.ToString(), Label = "Lax" },

        new() { Value = PokemonNatureEnum.Timid.ToString(), Label = "Timid" },
        new() { Value = PokemonNatureEnum.Hasty.ToString(), Label = "Hasty" },
        new() { Value = PokemonNatureEnum.Serious.ToString(), Label = "Serious" },
        new() { Value = PokemonNatureEnum.Jolly.ToString(), Label = "Jolly" },
        new() { Value = PokemonNatureEnum.Naive.ToString(), Label = "Naive" },

        new() { Value = PokemonNatureEnum.Modest.ToString(), Label = "Modest" },
        new() { Value = PokemonNatureEnum.Mild.ToString(), Label = "Mild" },
        new() { Value = PokemonNatureEnum.Quiet.ToString(), Label = "Quiet" },
        new() { Value = PokemonNatureEnum.Bashful.ToString(), Label = "Bashful" },
        new() { Value = PokemonNatureEnum.Rash.ToString(), Label = "Rash" },

        new() { Value = PokemonNatureEnum.Calm.ToString(), Label = "Calm" },
        new() { Value = PokemonNatureEnum.Gentle.ToString(), Label = "Gentle" },
        new() { Value = PokemonNatureEnum.Sassy.ToString(), Label = "Sassy" },
        new() { Value = PokemonNatureEnum.Careful.ToString(), Label = "Careful" },
        new() { Value = PokemonNatureEnum.Quirky.ToString(), Label = "Quirky" },
    };

}