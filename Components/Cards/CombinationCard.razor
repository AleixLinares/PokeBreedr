};

    private async Task ToggleParentsAsync()
    {
        if (!isParentsOpen)
        {
            isParentsOpen = true;
            isParentsLoading = true;
            await parentsRef!.OpenAsync();
            isParentsLoading = false;
        }
        else
        {
            isParentsOpen = false;
            isParentsLoading = true;
            await parentsRef!.CloseAsync();
            isParentsLoading = false;
        }
    }

    void OpenModal()
    {
        showModal = true;
    }

    void CloseModal()
    {
        showModal = false;
    }

    private static string BuildPokemonLabel(PokemonInfoDto pokemon)
    {
        var nickname = string.IsNullOrWhiteSpace(pokemon.Name)
            ? "No nickname"
            : pokemon.Name;

        return $"{pokemon.Pokemon} ({nickname}) " +
               $"{pokemon.HpIv}-{pokemon.AttackIv}-{pokemon.DefenseIv}-" +
               $"{pokemon.SpAttackIv}-{pokemon.SpDefenseIv}-{pokemon.SpeedIv}";
    }

    private async Task ToggleIgnore()
    {
        Model.IsIgnored = !Model.IsIgnored;
        if (Model.IsIgnored)
        {
            await ToastService.Success("Pokémon marked as ignored.");
        }
        else
        {
            await ToastService.Success("Pokémon removed from ignored list.");
        }
        await OnIgnore.InvokeAsync(Model.IsIgnored);
    }
}