@using PokeBreedr.Components.Utils
@using PokeBreedr.Enums
@using PokeBreedr.Models
@using PokeBreedr.Services

@inject IPokemonInitialLoad PokemonService
@inject ToastService ToastService

<div class="card-container">
    <div class="card-body-grid">

        <!-- Left column -->
        <div class="left-column">

            <!-- Pokemon -->
            <div class="field">
                <label>
                    Pokemon <span style="color:red">*</span>
                </label>

                <DropdownSearch Options="PokemonOptions"
                                Value="@Model.Pokemon"
                                isDisabled="@DisableAll"
                                ValueChanged="OnPokemonChanged" />

                <label>Nickname</label>

                <input class="text-input"
                       maxlength="200"
                       @bind="Model.Name"
                       placeholder="Nickname"
                       disabled="@(DisableAll || isLocked)"/>
            </div>

            <!-- Image -->
            <div class="pokemon-image-container">
                <img src="@(string.IsNullOrWhiteSpace(PokemonImage)
                                             ? "assets/defaultAvatar.png"
                                             : $"data:image/png;base64,{PokemonImage}")"
                     alt="Pokemon Avatar"
                     class="pokemon-image" />
                @if(Model.IsAlfa) 
                {
                    <img src = "assets/alphaIcon.webp"
                            class="pokemon-alpha-icon" 
                            alt="Alpha icon">
                }

                @if (Model.HasHiddenAbility)
                {
                    <img src="assets/HADiamond.png"
                         class="pokemon-ha-icon"
                         alt="HA icon">
                }
                
            </div>

        </div>

        <!-- Central column -->
        <div class="middle-column">

            <!-- Egg Group -->
            <div class="field">
                <label>
                    Egg Group:
                    @Model.EggGroup1@(Model.EggGroup2 == "" ? "" : $" / {Model.EggGroup2}")
                </label>
            </div>

            <div class="checkbox-row">
                <label>
                    Alfa
                    <input type="checkbox"
                           class="card-checkbox"
                           @bind="Model.IsAlfa"
                           disabled="@(DisableAll || isLocked)" />
                </label>

                <label>
                    HA
                    <input type="checkbox"
                           class="card-checkbox"
                           @bind="Model.HasHiddenAbility"
                           disabled="@(DisableAll || isLocked)" />
                </label>
            </div>

            <!-- Gender -->
            <div class="field">
                <label>
                    Gender <span style="color:red">*</span>
                </label>

                <Dropdown TValue="PokemonGenderEnum?"
                          Options="GenderOptions"
                          @key="GenderOptions"
                          @bind-Value="Model.Gender"
                          isDisabled="@(isLocked || isGenderLocked || DisableAll)" />
            </div>

            <!-- Nature -->
            <div class="field">
                <label>Nature</label>

                <Dropdown TValue="PokemonNatureEnum?"
                          Options="NatureOptions"
                          @bind-Value="Model.Nature"
                          isDisabled="@(isLocked || DisableAll)" />
            </div>

            <div class="field" style="margin-top: 5px">
                <label>Particles</label>

                <DropdownMultiple TValue="ParticleEnum"
                                  Options="ParticleOptions"
                                  isDisabled="@DisableAll"
                                  @bind-Values="Model.Particles" />
            </div>

        </div>

        <!-- Right column -->
        <div class="@(DisableAll ? "reduced-right-column" : "right-column")">

            @if (DisableAll)
            {
                <div class="iv-row">
                    <div class="iv-center">
                        <h3 class="iv-title">Hp</h3> 
                        <label style="margin-right: 15px">@Model.HpIv</label>
                    </div>
                </div>
                <div class="iv-row">
                    <div class="iv-center">
                        <h3 class="iv-title">Attack</h3>
                        <label style="margin-right: 15px">@Model.AttackIv</label>
                    </div>
                </div>
                <div class="iv-row">
                    <div class="iv-center">
                        <h3 class="iv-title">Defense</h3> 
                        <label style="margin-right: 15px">@Model.DefenseIv</label>
                    </div>
                </div>
                <div class="iv-row">
                    <div class="iv-center">
                        <h3 class="iv-title">SpAttack</h3>
                        <label style="margin-right: 15px">@Model.SpAttackIv</label>
                    </div>
                </div>
                <div class="iv-row">
                    <div class="iv-center">
                        <h3 class="iv-title">SpDefense</h3>
                        <label style="margin-right: 15px">@Model.SpDefenseIv</label>
                    </div>
                </div>
                <div class="iv-row">
                    <div class="iv-center">
                        <h3 class="iv-title">Speed</h3>
                        <label style="margin-right: 15px">@Model.SpeedIv</label>
                    </div>
                </div>
            }
            else
            {
                <div class="ivs-grid-body">

                <NumberSelector Title="Hp"
                                @bind-Value="@Model.HpIv"
                                MinValue="0"
                                MaxValue="31"
                                StepSmall="1"
                                StepLarge="10"
                                isDisabled="@(isLocked || DisableAll)" />

                <NumberSelector Title="Attack"
                                @bind-Value="@Model.AttackIv"
                                MinValue="0"
                                MaxValue="31"
                                StepSmall="1"
                                StepLarge="10"
                                isDisabled="@(isLocked || DisableAll)" />

                <NumberSelector Title="Defense"
                                @bind-Value="@Model.DefenseIv"
                                MinValue="0"
                                MaxValue="31"
                                StepSmall="1"
                                StepLarge="10"
                                isDisabled="@(isLocked || DisableAll)" />

                <NumberSelector Title="Sp. Attack"
                                @bind-Value="@Model.SpAttackIv"
                                MinValue="0"
                                MaxValue="31"
                                StepSmall="1"
                                StepLarge="10"
                                isDisabled="@(isLocked || DisableAll)" />

                <NumberSelector Title="Sp. Defense"
                                @bind-Value="@Model.SpDefenseIv"
                                MinValue="0"
                                MaxValue="31"
                                StepSmall="1"
                                StepLarge="10"
                                isDisabled="@(isLocked || DisableAll)" />

                <NumberSelector Title="Speed"
                                @bind-Value="@Model.SpeedIv"
                                MinValue="0"
                                MaxValue="31"
                                StepSmall="1"
                                StepLarge="10"
                                isDisabled="@(isLocked || DisableAll)" />

                </div>
            }

        </div>

    </div>
    @if (!DisableAll)
    {
        <div class="card-actions">
            @if (!areWeDeleting)
            {
                <button class="card-button" @onclick="Save"
                        disabled="@(_isActionBusy || string.IsNullOrWhiteSpace(Model.Pokemon) || Model.Gender == null)">
                    @(Model.IsSaved ? "Update" : "Save")
                </button>
            }           

            @if (Model.IsSaved)
            {
                @if (areWeDeleting)
                {
                    <label style="margin-left: 10px">Are you sure?</label>
                    <button style="color:red" disabled="@(!canWeDeleteAlready)" class="card-button" @onclick="Delete">
                        Yes, delete
                    </button>
                    <button style="color:green" class="card-button" @onclick="CancelDeleteProcess">
                        No, cancel
                    </button>
                }
                else
                {
                    <button style="color:red" disabled="@_isActionBusy" class="card-button" @onclick="StartDeleteProcess">
                        Delete
                    </button>
                }
            }
            else
            {
                <button disabled="@_isActionBusy" class="card-button" @onclick="Cancel">
                    Cancel
                </button>
            }

        </div>
    }

</div>

@code {

    [Parameter]
    public PokemonInfo Model { get; set; } = default!;

    [Parameter]
    public EventCallback<PokemonInfo> OnSave { get; set; }

    [Parameter]
    public EventCallback<PokemonInfo> OnCancel { get; set; }

    [Parameter]
    public EventCallback<PokemonInfo> OnDelete { get; set; }

    [Parameter]
    public bool DisableAll { get; set; }

    private bool isLocked => string.IsNullOrWhiteSpace(Model.Pokemon);
    private bool isGenderLocked = false;

    private List<DropdownOption> PokemonOptions = new();

    private string? PokemonImage = null;

    private bool _isActionBusy;
    private bool areWeDeleting;
    private bool canWeDeleteAlready;
    private CancellationTokenSource? _deleteCts;

    protected override async Task OnInitializedAsync()
    {
        NatureOptions = NatureOptions.OrderBy(i => i.Label).ToList();
        ParticleOptions = ParticleOptions.OrderBy(i => i.Label).ToList();

        var pokemonNames = await PokemonService.GetAllPokemonsNames();

        PokemonOptions = pokemonNames
            .Select(name => new DropdownOption
            {
                Value = name,
                Label = name
            })
            .ToList();

        // Si ya viene un pokemon seleccionado
        if (!string.IsNullOrWhiteSpace(Model.Pokemon))
        {
            await LoadPokemonInfo(Model.Pokemon);
        }
    }

    private async Task OnPokemonChanged(string pokemonName)
    {
        if (Model.Pokemon == pokemonName)
            return;

        Model.Pokemon = pokemonName;

        await LoadPokemonInfo(pokemonName);
    }

    private async Task LoadPokemonInfo(string pokemonName)
    {
        var pokemonInfo = await PokemonService.GetPokemonInfo(pokemonName);

        Model.EggGroup1 = pokemonInfo.EggGroup1;
        Model.EggGroup2 = pokemonInfo.EggGroup2;

        PokemonImage = pokemonInfo.ImageBase64;

        if(Model.EggGroup1 == "Ditto")
        {
            GenderOptions = new()
            {
                new() { Value = PokemonGenderEnum.Ditto.ToString(), Label = "Ditto" }
            };

            Model.Gender = PokemonGenderEnum.Ditto;
            isGenderLocked = true;
        }
        else if (Model.EggGroup1 == "Genderless")
        {
            GenderOptions = new()
            {
                new() { Value = PokemonGenderEnum.Genderless.ToString(), Label = "Genderless" }
            };

            Model.Gender = PokemonGenderEnum.Genderless;
            isGenderLocked = true;
        }
        else
        {
            GenderOptions = new()
            {
                new() { Value = PokemonGenderEnum.Male.ToString(), Label = "Male" },
                new() { Value = PokemonGenderEnum.Female.ToString(), Label = "Female" }
            };

            isGenderLocked = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private List<DropdownOption> GenderOptions = new();

    private List<DropdownOption> NatureOptions = new()
    {
        new() { Value = PokemonNatureEnum.Hardy.ToString(), Label = "Hardy" },
        new() { Value = PokemonNatureEnum.Lonely.ToString(), Label = "Lonely" },
        new() { Value = PokemonNatureEnum.Brave.ToString(), Label = "Brave" },
        new() { Value = PokemonNatureEnum.Adamant.ToString(), Label = "Adamant" },
        new() { Value = PokemonNatureEnum.Naughty.ToString(), Label = "Naughty" },

        new() { Value = PokemonNatureEnum.Bold.ToString(), Label = "Bold" },
        new() { Value = PokemonNatureEnum.Docile.ToString(), Label = "Docile" },
        new() { Value = PokemonNatureEnum.Relaxed.ToString(), Label = "Relaxed" },
        new() { Value = PokemonNatureEnum.Impish.ToString(), Label = "Impish" },
        new() { Value = PokemonNatureEnum.Lax.ToString(), Label = "Lax" },

        new() { Value = PokemonNatureEnum.Timid.ToString(), Label = "Timid" },
        new() { Value = PokemonNatureEnum.Hasty.ToString(), Label = "Hasty" },
        new() { Value = PokemonNatureEnum.Serious.ToString(), Label = "Serious" },
        new() { Value = PokemonNatureEnum.Jolly.ToString(), Label = "Jolly" },
        new() { Value = PokemonNatureEnum.Naive.ToString(), Label = "Naive" },

        new() { Value = PokemonNatureEnum.Modest.ToString(), Label = "Modest" },
        new() { Value = PokemonNatureEnum.Mild.ToString(), Label = "Mild" },
        new() { Value = PokemonNatureEnum.Quiet.ToString(), Label = "Quiet" },
        new() { Value = PokemonNatureEnum.Bashful.ToString(), Label = "Bashful" },
        new() { Value = PokemonNatureEnum.Rash.ToString(), Label = "Rash" },

        new() { Value = PokemonNatureEnum.Calm.ToString(), Label = "Calm" },
        new() { Value = PokemonNatureEnum.Gentle.ToString(), Label = "Gentle" },
        new() { Value = PokemonNatureEnum.Sassy.ToString(), Label = "Sassy" },
        new() { Value = PokemonNatureEnum.Careful.ToString(), Label = "Careful" },
        new() { Value = PokemonNatureEnum.Quirky.ToString(), Label = "Quirky" },
    };

    private List<DropdownOption> ParticleOptions = new()
{
    new() { Value = ParticleEnum.ShinyPhantom.ToString(), Label = "Shiny Phantom" },
    new() { Value = ParticleEnum.Phantom.ToString(), Label = "Phantom" },
    new() { Value = ParticleEnum.SpiritOfSpring.ToString(), Label = "Spirit of Spring" },
    new() { Value = ParticleEnum.XmasDecorations.ToString(), Label = "Xmas Decorations" },
    new() { Value = ParticleEnum.MenacingSpirit.ToString(), Label = "Menacing Spirit" },
    new() { Value = ParticleEnum.ShinyMenacingSpirit.ToString(), Label = "Shiny Menacing Spirit" },
    new() { Value = ParticleEnum.AnniversaryCake.ToString(), Label = "Anniversary Cake" },
    new() { Value = ParticleEnum.KantoFriends.ToString(), Label = "Kanto Friends" },
    new() { Value = ParticleEnum.ShinyKantoFriends.ToString(), Label = "Shiny Kanto Friends" },
    new() { Value = ParticleEnum.RedDragon.ToString(), Label = "Red Dragon" },
    new() { Value = ParticleEnum.EerieHowl.ToString(), Label = "Eerie Howl" },
    new() { Value = ParticleEnum.Graveyard.ToString(), Label = "Graveyard" },
    new() { Value = ParticleEnum.KingsFall.ToString(), Label = "King's Fall" },
    new() { Value = ParticleEnum.Zodiac.ToString(), Label = "Zodiac" },
    new() { Value = ParticleEnum.WitchsCat.ToString(), Label = "Witch's Cat" },
    new() { Value = ParticleEnum.Pumpcat.ToString(), Label = "Pumpcat" },
    new() { Value = ParticleEnum.SpinningScythe.ToString(), Label = "Spinning Scythe" },
    new() { Value = ParticleEnum.SpidersWeb.ToString(), Label = "Spider's Web" },
    new() { Value = ParticleEnum.ZombieGrip.ToString(), Label = "Zombie Grip" },
    new() { Value = ParticleEnum.PungentStench.ToString(), Label = "Pungent Stench" },
    new() { Value = ParticleEnum.WitchsHaze.ToString(), Label = "Witch's Haze" },
    new() { Value = ParticleEnum.PumpkidsTreat.ToString(), Label = "Pumpkid's Treat" },
    new() { Value = ParticleEnum.PaperLantern.ToString(), Label = "Paper Lantern" },
    new() { Value = ParticleEnum.Fireworks.ToString(), Label = "Fireworks" },
    new() { Value = ParticleEnum.BlackHole.ToString(), Label = "Black Hole" },
