    new() { Value = ParticleEnum.ShinyDarkCrystal.ToString(), Label = "Shiny Dark Crystal" },
    new() { Value = ParticleEnum.DarkCrystal.ToString(), Label = "Dark Crystal" },
    new() { Value = ParticleEnum.BloodLotusField.ToString(), Label = "Blood Lotus Field" },
    new() { Value = ParticleEnum.LotusField.ToString(), Label = "Lotus Field" },
};

    private async Task Save()
    {
        if (_isActionBusy)
            return;

        try
        {
            _isActionBusy = true;

            await OnSave.InvokeAsync(Model);            
            await ToastService.Success("Pokémon saved successfully.");

            // Cooldown anti-spam
            await Task.Delay(300);
        }
        catch (Exception)
        {
            await ToastService.Error("Failed to save Pokémon. Please try again.");
        }
        finally
        {
            _isActionBusy = false;
        }
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync(Model);
    }

    private async Task Delete()
    {
        if (_isActionBusy)
            return;

        try
        {
            _isActionBusy = true;

            // Tu lógica de guardado
            await OnDelete.InvokeAsync(Model);
            await ToastService.Success("Pokemon deleted successfully");

            // Cooldown anti-spam
            await Task.Delay(300);
        }
        catch (Exception)
        {
            await ToastService.Error("Failed to delete Pokémon. Please try again.");
        }
        finally
        {
            _isActionBusy = false;
            canWeDeleteAlready = false;
            areWeDeleting = false;
        }
    }

    private async Task StartDeleteProcess()
    {
        _deleteCts?.Cancel();
        _deleteCts?.Dispose();

        _deleteCts = new CancellationTokenSource();

        areWeDeleting = true;
        canWeDeleteAlready = false;

        StateHasChanged();

        try
        {
            await Task.Delay(600, _deleteCts.Token);

            canWeDeleteAlready = true;
        }
        catch (TaskCanceledException)
        {
            // Cancelled, ignore
        }

        StateHasChanged();
    }

    private void CancelDeleteProcess()
    {
        _deleteCts?.Cancel();

        areWeDeleting = false;
        canWeDeleteAlready = false;

        StateHasChanged();
    }
}