@using Microsoft.AspNetCore.Components.Rendering
@using PokeBreedr.Components.Utils
@using PokeBreedr.Enums
@using PokeBreedr.Models

<div class="card-container">

    <div class="card-header">
        Pokemon Info
    </div>

    <div class="card-body">

        <!-- Pokemon -->
        <div class="field">
            <label>Pokemon</label>

            <DropdownSearch Options="PokemonOptions"
                      @bind-Value="Model.Pokemon" />
        </div>

        <!-- Gender -->
        <div class="field">
            <label>Gender</label>

            <Dropdown TValue="PokemonGenderEnum"
                Options="GenderOptions"
                @bind-Value="Model.Gender" />
        </div>

        <!-- Nature -->
        <div class="field">
            <label>Nature</label>

            <Dropdown TValue="PokemonNatureEnum"
                      Options="NatureOptions"
                      @bind-Value="Model.Nature" />
        </div>

        <!-- Egg Group -->
        <div class="field">
            <label>Egg Group</label>

            <input value="@Model.EggGroup" disabled />
        </div>

        <NumberSelector 
            Value="@Model.DefenseIv"
            MinValue="0"
            MaxValue="31"
            StepSmall="1"
            StepLarge="10" />

    </div>

</div>

@code {

    private PokemonInfo Model = new()
    {
        Pokemon = "pikachu",
        EggGroup = PokemonEggGroupEnum.Monster,
        Gender = PokemonGenderEnum.Male,
        Nature = PokemonNatureEnum.Adamant,
        HpIv = 31,
        AttackIv = 31,
        DefenseIv = 17,
        SpAttackIv = 31,
        SpDefenseIv = 31,
        SpeedIv = 31
    };

    private List<DropdownOption> PokemonOptions = new()
    {
        new() { Value = "bulbasaur", Label = "Bulbasaur" },
        new() { Value = "charmander", Label = "Charmander" },
        new() { Value = "squirtle", Label = "Squirtle" },
        new() { Value = "pikachu", Label = "Pikachu" },
    };

    private List<DropdownOption> GenderOptions = new()
    {
        new() { Value = PokemonGenderEnum.Male.ToString(), Label = "Male" },
        new() { Value = PokemonGenderEnum.Female.ToString(), Label = "Female" },
        new() { Value = PokemonGenderEnum.Genderless.ToString(), Label = "Genderless" },
        new() { Value = PokemonGenderEnum.Ditto.ToString(), Label = "Ditto" },
    };

    private List<DropdownOption> NatureOptions = new()
    {
        new() { Value = PokemonNatureEnum.Adamant.ToString(), Label = "Adamant" },
        new() { Value = PokemonNatureEnum.Bashful.ToString(), Label = "Bashful" },
        new() { Value = PokemonNatureEnum.Bold.ToString(), Label = "Bold" },
        new() { Value = PokemonNatureEnum.Brave.ToString(), Label = "Brave" },
    };
}