    new() { Value = ParticleEnum.RisingStar.ToString(), Label = "Rising Star" },
    new() { Value = ParticleEnum.Snowflake.ToString(), Label = "Snowflake" },
    new() { Value = ParticleEnum.Present.ToString(), Label = "Present" },
    new() { Value = ParticleEnum.Hitodama.ToString(), Label = "Hitodama" },
    new() { Value = ParticleEnum.Bats.ToString(), Label = "Bats" },
    new() { Value = ParticleEnum.Ghosts.ToString(), Label = "Ghosts" },
